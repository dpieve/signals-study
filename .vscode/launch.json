{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Consumer",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/consumer/consumer.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set disassembly flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build: Consumer only (Debug)"
    },
    {
      "name": "Debug: Client (ICU Monitor)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/client/icu_monitor.exe",
      "args": ["--server", "localhost:50051"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build: Client only (Debug)"
    },
    {
      "name": "Debug: Generator Tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/generator/generator_tests.exe",
      "args": ["--gtest_color=yes"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "Build: All (Debug)"
    },
    {
      "name": "Debug: Consumer Tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/consumer/consumer_tests.exe",
      "args": ["--gtest_color=yes"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "Build: All (Debug)"
    },
    {
      "name": "Debug: Client Tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/client/client_tests.exe",
      "args": ["--gtest_color=yes"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "Build: All (Debug)"
    }
  ]
}
